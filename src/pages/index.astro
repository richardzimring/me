---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteOfTheDay from '../components/QuoteOfTheDay.astro';
import WordOfTheDay from '../components/WordOfTheDay.astro';
import { projects } from '../data/projects';
import { getCollection } from 'astro:content';

const dayIndex = Math.floor(Date.now() / (1000 * 60 * 60 * 24));
// Roughly 1 in 3 days surface a word instead of a quote.
const showWord = dayIndex % 3 === 0;

const isDev = import.meta.env.DEV;
const allPosts = (await getCollection('posts'))
  .filter((post) => isDev || !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d: Date) => d.toISOString().slice(0, 10); // YYYY-MM-DD for the ls output

const estimateRead = (slug: string) => {
  // Rough read-time by essay slug — updated when essays ship.
  const minutes: Record<string, number> = {
    'on-ai-and-believability': 12,
    pokes: 9,
    'the-productivity-squeeze': 18,
  };
  return minutes[slug] ?? 8;
};
---

<BaseLayout
  title="Richard Zimring"
  description="A personal site"
  active="index"
  file="index.html"
  path="/"
>
  {/* $ whoami --verbose */}
  <div class="prompt">
    <div class="prompt-head">
      <span class="user">richard</span><span class="sep">@</span><span class="user">zimring</span
      ><span class="sep">:</span><span class="path">~</span><span class="sep"> $</span>
    </div>
    <div class="prompt-cmd">
      <span class="cmd">whoami</span>
      <span class="flag">--verbose</span>
    </div>
  </div>

  <section class="whoami">
    <span class="whoami-tag">/etc/about.txt</span>
    <h1>
      <span class="name">richard_zimring</span><span class="punct"> ::</span>
      <span class="role"> software_engineer(ai, sports)</span>
    </h1>
    <div class="whoami-body">
      <p>
        Leading <a href="https://maven.sportradar.com">Maven</a> at <a href="https://sportradar.com"
          >Sportradar</a
        > — a generative AI platform for sports research used on-air during the 2025 World Series and
        2026 Super Bowl.
      </p>
      <p>
        Previously: crypto-market research at <a href="https://kellogg.northwestern.edu">Kellogg</a
        >, CS at Northwestern.
      </p>
    </div>
  </section>

  <div class="currently">
    <span class="currently-tag">currently.yml</span>
    <div class="currently-row">
      <span class="k">building</span><span class="colon">:</span>
    </div>
    <div class="currently-nested">
      <div class="currently-row">
        <span class="k">agent</span><span class="colon">:</span>
        <span class="v">architecture · evals · accuracy</span>
      </div>
      <div class="currently-row">
        <span class="k">platform</span><span class="colon">:</span>
        <span class="v">ui · rest · mcp · slack</span>
      </div>
    </div>
    <div class="currently-row">
      <span class="k">applying</span><span class="colon">:</span>
      <span class="v">systems engineering</span>
    </div>
    <div class="currently-row">
      <span class="k">bridging</span><span class="colon">:</span>
    </div>
    <div class="currently-item">- product ↔ design ↔ engineering</div>
    <div class="currently-item">- demo ↔ production</div>
  </div>

  {/* Writing — ls -lht essays/ */}
  {
    allPosts.length > 0 && (
      <section class="section">
        <div class="prompt">
          <div class="prompt-head">
            <>
              <span class="user">richard</span>
              <span class="sep">@</span>
              <span class="user">zimring</span>
              <span class="sep">:</span>
              <span class="path">~/writing</span>
              <span class="sep"> $</span>
            </>
          </div>
          <div class="prompt-cmd">
            <span class="cmd">ls</span> <span class="flag">-lht</span>{' '}
            <span class="arg">posts/</span>
          </div>
        </div>

        <div class="ls" role="list">
          <div class="ls-head" aria-hidden="true">
            <div class="date">date</div>
            <div>title</div>
            <div class="size">read</div>
            <div class="perms">perms</div>
          </div>
          {allPosts.map((post) => (
            <a
              class={`ls-row${post.data.draft ? ' draft' : ''}`}
              href={`/posts/${post.id}/`}
              role="listitem"
            >
              <div class="date">{formatDate(post.data.date)}</div>
              <div class="file">
                <span class="title">{post.id}.mdx</span>
                {(post.data.description || post.data.title) && (
                  <span class="dek">{post.data.description || post.data.title}</span>
                )}
              </div>
              <div class="size">{estimateRead(post.id)}m</div>
              <div class="perms">-rw-r--r--</div>
            </a>
          ))}
          {allPosts.some((p) => p.data.draft) && (
            <div class="ls-legend">
              <span class="star">*</span> unpublished draft
            </div>
          )}
        </div>
      </section>
    )
  }

  {/* Projects — git log --oneline --graph */}
  <section class="section">
    <div class="prompt">
      <div class="prompt-head">
        <span class="user">richard</span><span class="sep">@</span><span class="user">zimring</span
        ><span class="sep">:</span><span class="path">~/projects</span><span class="sep"> $</span>
      </div>
      <div class="prompt-cmd">
        <span class="cmd">git log</span>
        <span class="flag">--oneline</span>
        <span class="flag">--graph</span>
      </div>
    </div>

    <div class="gitlog">
      {
        projects.map((p) => (
          <div class="git-entry">
            <div class="git-graph">
              <div class="node" />
              <div class="line" />
            </div>
            <div>
              <div class="git-meta">
                <span class="hash">{p.hash}</span>
                <span>{p.ref}</span>
                <span class="tag">{p.tag}</span>
              </div>
              <div class="git-msg">
                <a href={p.href}>{p.name}</a> — {p.tagline}
              </div>
              <div class="git-body">{p.description}</div>
              <div class="git-stack">
                <span class="plus">+</span> {p.stack}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  {/* Links — cat elsewhere.yml */}
  <section class="section">
    <div class="prompt">
      <div class="prompt-head">
        <span class="user">richard</span><span class="sep">@</span><span class="user">zimring</span
        ><span class="sep">:</span><span class="path">~</span><span class="sep"> $</span>
      </div>
      <div class="prompt-cmd">
        <span class="cmd">cat</span>
        <span class="arg">elsewhere.yml</span>
      </div>
    </div>

    <div class="kvlist">
      <div class="kv-row">
        <div>
          <span class="k">github</span><span class="colon">: </span><span class="v"
            ><a href="https://github.com/richardzimring">github.com/richardzimring</a></span
          >
        </div>
        <div class="hint">↗ open</div>
      </div>
      <div class="kv-row">
        <div>
          <span class="k">linkedin</span><span class="colon">: </span><span class="v"
            ><a href="https://linkedin.com/in/richardzimring">linkedin.com/in/richardzimring</a
            ></span
          >
        </div>
        <div class="hint">↗ open</div>
      </div>
      <div class="kv-row">
        <div>
          <span class="k">resume</span><span class="colon">: </span><span class="v"
            ><a href="/resume/">richardzimring.com/resume</a></span
          >
        </div>
        <div class="hint">→ local</div>
      </div>
    </div>
  </section>

  {showWord ? <WordOfTheDay /> : <QuoteOfTheDay />}

  <div class="prompt" style="margin-top: 32px;">
    <div class="prompt-head">
      <span class="user">richard</span><span class="sep">@</span><span class="user">zimring</span
      ><span class="sep">:</span><span class="path">~</span><span class="sep"> $</span>
    </div>
    <div class="prompt-cmd"><span class="cursor"></span></div>
  </div>
</BaseLayout>
