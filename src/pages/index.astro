---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Richard Zimring" description="Software engineer. Personal website and writing.">
  <section class="hero">
    <p class="bio">
      Building <a href="https://maven.sportradar.com">Maven</a> at <a href="https://sportradar.com"
        >Sportradar</a
      >.
    </p>
  </section>

  {
    allPosts.length > 0 && (
      <section>
        <h2 class="section-heading">Writing</h2>
        <ul class="link-list">
          {allPosts.map((post) => (
            <li>
              <a href={`/me/posts/${post.id}/`}>{post.data.title}</a>
              <span class="date">
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                })}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section>
    <h2 class="section-heading">Projects</h2>
    <ul class="link-list">
      <li>
        <a href="https://apps.apple.com/us/app/gather-plan-with-friends/id6759443297">Gather</a>
        <span class="date">iOS app</span>
      </li>
      <li>
        <a href="https://richardzimring.github.io/heatstrike">Heatstrike</a>
        <span class="date">Web</span>
      </li>
    </ul>
  </section>

  <section>
    <h2 class="section-heading">Links</h2>
    <ul class="link-list">
      <li><a href="/me/resume/">Resume</a></li>
      <li><a href="https://github.com/richardzimring">GitHub</a></li>
      <li><a href="https://linkedin.com/in/richardzimring">LinkedIn</a></li>
      <li><a href="https://x.com/richardzimring">X</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .hero {
    margin-bottom: var(--space-lg);
  }

  .bio {
    font-size: var(--text-lg);
    max-width: var(--max-width-prose);
  }
</style>
