---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const isDev = import.meta.env.DEV;
const allPosts = (await getCollection('posts'))
  .filter((post) => isDev || !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Richard Zimring" description="Software engineer. Personal website and writing.">
  <section>
    <p>
      Building AI agents for sports. Currently leading <a href="https://maven.sportradar.com"
        >Maven</a
      > at <a href="https://sportradar.com">Sportradar</a>, a generative AI platform for sports
      research, used by major broadcast networks to answer statistical questions and find storylines
      for live broadcast, including during the 2025 World Series and 2026 Superbowl.
    </p>
    <p>
      Previously researched crypto markets at <a href="https://kellogg.northwestern.edu">Kellogg</a
      >. Studied CS at Northwestern.
    </p>
    <p>See my full <a href="/resume/">resume</a>.</p>
  </section>

  {
    allPosts.length > 0 && (
      <section>
        <h2 class="section-heading">Writing</h2>
        <ul class="link-list">
          {allPosts.map((post) => (
            <li>
              <a href={`/posts/${post.id}/`}>{post.data.title}</a>
              {post.data.draft && <span class="draft-badge">draft</span>}
              <span class="date">
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                })}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section>
    <h2 class="section-heading">Projects</h2>
    <ul class="link-list">
      <li>
        <a href="https://apps.apple.com/us/app/gather-plan-with-friends/id6759443297">Gather</a>
        <span class="date">iOS app</span>
      </li>
      <li>
        <a href="https://richardzimring.github.io/heatstrike">Heatstrike</a>
        <span class="date">Web</span>
      </li>
    </ul>
  </section>

  <section>
    <h2 class="section-heading">Links</h2>
    <ul class="link-list">
      <li><a href="https://github.com/richardzimring">GitHub</a></li>
      <li><a href="https://linkedin.com/in/richardzimring">LinkedIn</a></li>
    </ul>
  </section>
</BaseLayout>
