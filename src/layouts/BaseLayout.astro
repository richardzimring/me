---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Statusbar from '../components/Statusbar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  path?: string;
  active?: 'index' | 'writing' | 'resume' | null;
  file?: string;
}

const { title, description, ogImage, path = '~', active = null, file = 'index.html' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} />
  </head>
  <body>
    <div class="window">
      <Header path={path} active={active} />
      <main class="pane">
        <slot />
      </main>
      <Statusbar file={file} />
    </div>
    <script>
      document.querySelectorAll('a[href]').forEach((a) => {
        const href = (a as HTMLAnchorElement).href;
        try {
          const url = new URL(href, window.location.href);
          if (url.origin !== window.location.origin) {
            a.setAttribute('target', '_blank');
            a.setAttribute('rel', 'noopener noreferrer');
          }
        } catch {
          // malformed href — leave as-is
        }
      });
    </script>
  </body>
</html>
