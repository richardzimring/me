---
import BaseLayout from './BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
---

<BaseLayout
  title="Richard Zimring"
  description="Resume"
  ogImage="/og/resume.png"
  active="resume"
  file="resume.mdx"
  path="/resume/"
>
  <div class="prompt">
    <div class="prompt-head">
      <span class="user">richard</span><span class="sep">@</span><span class="user">zimring</span
      ><span class="sep">:</span><span class="path">~</span><span class="sep"> $</span>
    </div>
    <div class="prompt-cmd"><span class="cmd">cat</span> <span class="arg">resume.mdx</span></div>
  </div>

  <article class="resume prose">
    <h1>Richard Zimring</h1>
    <p class="post-description" style="margin-bottom: var(--space-xl);">
      Software engineer · Minneapolis, MN
    </p>
    <slot />
  </article>

  <Terminal path="~/resume" />
</BaseLayout>
