---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const title = frontmatter?.title ?? 'Resume';
const description = frontmatter?.description ?? "Richard Zimring's resume.";
---

<BaseLayout title={`Richard Zimring — ${title}`} description={description}>
  <div class="resume prose">
    <slot />
  </div>
</BaseLayout>
