---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Statusbar from '../components/Statusbar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  date: Date;
  ogImage?: string;
  headings: { depth: number; slug: string; text: string }[];
  draft?: boolean;
  slug?: string;
}

const { title, description, date, ogImage, headings, draft, slug } = Astro.props;

const metaDescription = description ?? `Richard Zimring — ${title}`;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const iso = date.toISOString().slice(0, 10);
const fileName = slug ? `${slug}.mdx` : 'post.mdx';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Richard Zimring — ${title}`}
      description={metaDescription}
      ogImage={ogImage}
    />
  </head>
  <body>
    <div class="window">
      <Header path={`/writing/${fileName}`} active="writing" />
      <main class="pane">
        <TableOfContents headings={headings} />
        <article class="prose">
          <div class="post-kicker">
            <span class="user">$</span>
            <span class="cmd">cat</span>
            <span class="arg">{fileName}</span>
          </div>
          {draft && <div class="draft-banner">Draft — not published</div>}
          <h1 class="post-title">{title}</h1>
          {description && <p class="post-description">{description}</p>}
          <p class="post-meta">
            {formattedDate}
            <span style="color: var(--muted-2);">·</span>
            <time datetime={iso}>{iso}</time>
          </p>
          <slot />
        </article>
      </main>
      <Statusbar file={fileName} />
    </div>
    <script>
      document.querySelectorAll('a[href]').forEach((a) => {
        const href = (a as HTMLAnchorElement).href;
        try {
          const url = new URL(href, window.location.href);
          if (url.origin !== window.location.origin) {
            a.setAttribute('target', '_blank');
            a.setAttribute('rel', 'noopener noreferrer');
          }
        } catch {
          // malformed href — leave as-is
        }
      });
    </script>
  </body>
</html>
