---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  homeIconOnly?: boolean;
}

const { homeIconOnly = false } = Astro.props;
---

<header class="site-header">
  <a href="/me/" class="site-title" aria-label={homeIconOnly ? 'Home' : undefined}>
    {
      homeIconOnly ? (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z" />
          <polyline points="9 21 9 12 15 12 15 21" />
        </svg>
      ) : (
        'Richard Zimring'
      )
    }
  </a>
  <ThemeToggle />
</header>
